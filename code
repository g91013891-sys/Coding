<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ultimate Code Editor</title>

<style>
body {
  margin: 0;
  background: #111;
  color: white;
  font-family: sans-serif;
}

/* tombol toggle */
.toggle-btn {
  position: fixed;
  top: 10px;
  right: 10px;
  z-index: 999;
  padding: 6px 10px;
  background: #333;
  border: none;
  color: white;
  cursor: pointer;
}

/* preview */
iframe {
  width: 100%;
  height: 40vh;
  border: none;
  background: white;
  transition: 0.3s;
}

/* editor */
.editor {
  height: 60vh;
  display: flex;
  flex-direction: column;
  transition: 0.3s;
}

.tabs {
  display: flex;
  background: #222;
}

.tab {
  padding: 10px;
  cursor: pointer;
}

.tab.active {
  background: #333;
}

textarea {
  flex: 1;
  width: 100%;
  background: #000;
  color: #0f0;
  border: none;
  padding: 10px;
  font-family: monospace;
  display: none;
}

textarea.active {
  display: block;
}
</style>
</head>

<body>

<button class="toggle-btn" onclick="toggleEditor()">👁️</button>

<iframe id="preview"></iframe>

<div class="editor">
  <div class="tabs">
    <div class="tab active" onclick="openTab('html', this)">HTML</div>
    <div class="tab" onclick="openTab('css', this)">CSS</div>
    <div class="tab" onclick="openTab('js', this)">JS</div>
  </div>

  <textarea id="html" class="active"><h1>Hello World 🚀</h1></textarea>
  <textarea id="css">body { text-align:center; }</textarea>
  <textarea id="js">console.log('gas')</textarea>
</div>

<script>
const tabs = document.querySelectorAll(".tab");
const areas = document.querySelectorAll("textarea");

function openTab(id, el) {
  tabs.forEach(t => t.classList.remove("active"));
  el.classList.add("active");

  areas.forEach(a => a.classList.remove("active"));
  document.getElementById(id).classList.add("active");
}

function update() {
  const html = document.getElementById("html").value;
  const css = document.getElementById("css").value;
  const js = document.getElementById("js").value;

  document.getElementById("preview").srcdoc = `
    <html>
    <head><style>${css}</style></head>
    <body>
      ${html}
      <script>${js}<\/script>
    </body>
    </html>
  `;
}

/* auto run */
areas.forEach(a => {
  a.addEventListener("input", update);
});

update();

/* toggle editor */
let hidden = false;

function toggleEditor() {
  const editor = document.querySelector(".editor");
  const preview = document.getElementById("preview");

  hidden = !hidden;

  if (hidden) {
    editor.style.display = "none";
    preview.style.height = "100vh";
  } else {
    editor.style.display = "flex";
    preview.style.height = "40vh";
  }
}

/* OFFLINE MODE */
if ("serviceWorker" in navigator) {
  const swCode = `
    const CACHE_NAME = "editor-v1";
    const FILES = ["/"];

    self.addEventListener("install", e => {
      e.waitUntil(
        caches.open(CACHE_NAME).then(cache => cache.addAll(FILES))
      );
    });

    self.addEventListener("fetch", e => {
      e.respondWith(
        caches.match(e.request).then(res => res || fetch(e.request))
      );
    });
  `;

  const blob = new Blob([swCode], { type: "text/javascript" });
  const swURL = URL.createObjectURL(blob);

  navigator.serviceWorker.register(swURL);
}
</script>

</body>
</html>
